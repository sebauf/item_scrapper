# Copier en .env (jamais commité) et ajuster les valeurs avant `docker compose up`.

# --- MongoDB ---
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=password
MONGODB_URI=mongodb://admin:password@mongodb:27017/scrapper?authSource=admin

# --- Postgres (metadata Airflow) ---
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow

# --- Airflow ---
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=

# Orchestrateur utilisé par le DAG pour lancer scrape/refine/train/score : "docker" en local (DockerOperator),
# "kubernetes" en cluster (KubernetesPodOperator, voir k8s/).
PIPELINE_EXECUTOR=docker

# Préfixe des images poussées par la CI (ghcr.io/<owner>/item_scrapper-<service>)
IMAGE_REGISTRY=ghcr.io/YOUR_GITHUB_USERNAME/item_scrapper

# GID du groupe "docker" sur l'hôte (stat -c '%g' /var/run/docker.sock), nécessaire au scheduler
# pour lancer des conteneurs sibling via DockerOperator.
DOCKER_GID=984
