# Copier en secrets.env (jamais commité, ignoré par git) à côté de ce fichier,
# puis ajuster les valeurs avant de lancer `kubectl apply -k k8s/overlays/prod`.
# kustomize en fait un Secret "price-tracker-secrets" (cf. base/kustomization.yaml).

MONGODB_URI=mongodb://admin:CHANGEME@mongodb-host:27017/scrapper?authSource=admin

# Metadata DB d'Airflow (Postgres déployé par k8s/base/postgres.yaml)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=CHANGEME
# Doit reprendre les mêmes valeurs que ci-dessus :
# postgresql+psycopg2://<AIRFLOW_DB_USER>:<AIRFLOW_DB_PASSWORD>@airflow-postgres/airflow
AIRFLOW_SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:CHANGEME@airflow-postgres/airflow

# Compte admin créé dans la webui Airflow par le Job airflow-init
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=CHANGEME

# Générer avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGEME
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=CHANGEME
